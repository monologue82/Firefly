---
import { Icon } from "astro-icon/components";
import VideoGrid from "@/components/pages/videos/VideoGrid.svelte";
import { siteConfig } from "@/config";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateI18nWithTime } from "@/utils/date-utils";

if (!siteConfig.pages.videos) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());
const BILIBILI_UID = siteConfig.anime?.bilibili?.uid || "";
const isConfigured = !!BILIBILI_UID;
---

<MainGridLayout title="我的视频" description="我的 Bilibili 投稿视频">
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 sm:px-6 md:px-9 py-4 sm:py-6 relative w-full">
      <div class="relative w-full mb-8">
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
              <Icon is:inline name="fa7-brands:bilibili" class="text-[1.5rem]"></Icon>
            </div>
            <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
              我的视频
            </div>
          </div>
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
            我的 Bilibili 投稿视频，数据来自 Bilibili
          </p>
          <p class="text-xs text-neutral-500 dark:text-neutral-500 mt-2">
            最后更新：{buildTime}
          </p>
        </div>

        {!isConfigured ? (
          <div class="text-center py-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-(--btn-regular-bg) rounded-full mb-6 border border-(--line-divider)">
              <Icon is:inline name="material-symbols:settings" class="text-[2rem] text-(--btn-content)" />
            </div>
            <h2 class="text-xl font-semibold text-black/80 dark:text-white/80 mb-3">
              未配置 Bilibili UID
            </h2>
            <p class="text-black/60 dark:text-white/60 mb-4 max-w-md mx-auto">
              请在 src/config/siteConfig.ts 中配置 Bilibili UID
            </p>
          </div>
        ) : (
          <VideoGrid client:load uid={BILIBILI_UID} />
        )}
      </div>
    </div>
  </div>
</MainGridLayout>